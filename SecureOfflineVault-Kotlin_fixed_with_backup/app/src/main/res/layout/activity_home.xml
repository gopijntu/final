<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Menu area -->
    <ScrollView
        android:id="@+id/menuScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvFooter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <LinearLayout
            android:orientation="vertical"
            android:padding="32dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBanks"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="Banks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:paddingVertical="16dp"
                android:layout_marginTop="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCards"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="Cards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:paddingVertical="16dp"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPolicies"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="Policies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:paddingVertical="16dp"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAadhar"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="Aadhar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:paddingVertical="16dp"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="Settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:paddingVertical="16dp"
                android:layout_marginTop="32dp"/>

            <!-- ✅ NEW Logout button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="Logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:paddingVertical="16dp"
                android:layout_marginTop="32dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Designed &amp; Created by Gopinath Kumbha"
        android:textAppearance="?attr/textAppearanceCaption"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
